generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  // shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  stacks Stack[]

  @@index([createdAt])
  @@map("user")
}

model Duration {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  start Int
  stop  Int

  track   Track?  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  trackId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trackId])
  @@map("duration")
}

model Track {
  id String @id

  type          String
  label         String
  color         String
  sortOrder     Int
  isMute        Boolean
  isSolo        Boolean
  isFavourite   Boolean
  volumePercent Int
  low           Int
  mid           Int
  high          Int
  lowFrequency  Int
  highFrequency Int
  isBypass      Boolean

  stack   Stack  @relation(fields: [stackId], references: [id], onDelete: Cascade)
  stackId String

  durations  Duration[]
  audioTrack AudioTrack? @relation(name: "TrackToAudioTrack")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stackId, sortOrder])
  @@index([stackId])
  @@map("track")
}

model AudioTrack {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  filename     String
  downloadUrl  String?
  loopLength   Int
  offset       Float   @default(0)
  duration     Float   @default(0)
  pitch        Float   @default(0)
  timestretch  Float   @default(1)
  fullDuration Float   @default(0)

  sampleId String? @db.Uuid 
  sample   Sample? @relation(fields: [sampleId], references: [id], onDelete: SetNull)

  track   Track  @relation(name: "TrackToAudioTrack", fields: [trackId], references: [id], onDelete: Cascade)
  trackId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trackId])
  @@index([sampleId])
  @@map("audio_track")
}

model Stack {
  id String @id

  title     String
  sortOrder Int

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.Uuid

  transport   Transport?
  tracks      Track[]
  screen      Screen?
  destination Destination?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, sortOrder])
  @@index([userId])
  @@index([sortOrder])
  @@map("stack")
}

model Transport {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  tempo     Float
  isLoop    Boolean
  loopStart Int
  loopEnd   Int

  stack   Stack  @relation(fields: [stackId], references: [id], onDelete: Cascade)
  stackId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stackId])
  @@map("transport")
}

model Screen {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  gridLengthInBars Int

  stack   Stack  @relation(fields: [stackId], references: [id], onDelete: Cascade)
  stackId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stackId])
  @@map("screen")
}

model Destination {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  volumePercent Int
  isMute        Boolean

  stack   Stack  @relation(fields: [stackId], references: [id], onDelete: Cascade)
  stackId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stackId])
  @@map("destination")
}

model Sample {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  filename    String
  downloadUrl String   @unique

  duration    Float    @default(0)
  bpm         Int?
  key         String?

  collection  String
  subcategory String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  audioTracks AudioTrack[]

  @@unique([filename, collection, subcategory])
  @@index([collection])
  @@index([collection, subcategory])

  @@map("sample")
}