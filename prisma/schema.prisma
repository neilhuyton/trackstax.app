generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  stacks Stack[]

  @@index([createdAt])
  @@map("users")
}

model Stack {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String
  sortOrder Int

  userId String @db.Uuid

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transport   Transport?
  tracks      Track[]
  destination Destination?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId, sortOrder])
  @@index([userId])
  @@index([sortOrder])
  @@map("stacks")
}

model Transport {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tempo     Float   @default(132)
  isLoop    Boolean @default(false)
  loopStart Int     @default(0)
  loopEnd   Int     @default(0)

  stackId String @unique @db.Uuid

  stack Stack @relation(fields: [stackId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([stackId])
  @@map("transports")
}

model Destination {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  volumePercent Int     @default(100)
  isMute        Boolean @default(false)

  stackId String @unique @db.Uuid

  stack Stack @relation(fields: [stackId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([stackId])
  @@map("destinations")
}

model Track {
  id            String  @id @db.Uuid
  type          String
  label         String
  color         String
  sortOrder     Int
  isMute        Boolean
  isSolo        Boolean
  isFavourite   Boolean
  volumePercent Int     @default(75)
  low           Int
  mid           Int
  high          Int
  lowFrequency  Int
  highFrequency Int
  isBypass      Boolean
  loopLength    Int     @default(4)

  durations     Json    @default("[]")

  stackId       String  @db.Uuid

  stack         Stack   @relation(fields: [stackId], references: [id], onDelete: Cascade)
  audioTrack    AudioTrack? @relation("TrackToAudioTrack")
  samplerTrack  SamplerTrack? @relation("TrackToSamplerTrack")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@index([stackId, sortOrder])
  @@index([stackId])
  @@map("tracks")
}

model AudioTrack {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  filename     String
  downloadUrl  String?
  offset       Float   @default(0)
  duration     Float   @default(0)
  pitch        Float   @default(0)
  timestretch  Float   @default(1)
  fullDuration Float   @default(0)

  sampleId String? @db.Uuid
  trackId  String  @unique @db.Uuid

  sample Sample? @relation(fields: [sampleId], references: [id], onDelete: SetNull)
  track  Track   @relation("TrackToAudioTrack", fields: [trackId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([trackId])
  @@index([sampleId])
  @@map("audio_tracks")
}

model SamplerTrack {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pattern        Json
  attackMs       Int    @default(10)
  releaseMs      Int    @default(200)
  zones          Json   @default("[]")

  trackId        String @unique @db.Uuid

  track          Track  @relation("TrackToSamplerTrack", fields: [trackId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("sampler_tracks")
}

model Collection {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String  @unique
  slug        String  @unique
  coverImage  String?
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  samples Sample[]

  @@map("collections")
}

model Sample {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  filename    String
  downloadUrl String @unique

  duration Float   @default(0)
  bpm      Int?
  key      String?

  collectionName String
  subcategory    String?

  collection  Collection   @relation(fields: [collectionName], references: [name], onDelete: Cascade)
  audioTracks AudioTrack[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([filename, collectionName, subcategory])
  @@index([collectionName, subcategory, bpm])
  @@map("samples")
}